<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Premium Blog</title>
    
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;800&display=swap" rel="stylesheet">
    
    <style>
        /* --- ĐỊNH NGHĨA BIẾN MÀU SANG TRỌNG --- */
        :root {
            --primary-gradient: linear-gradient(135deg, #2563eb, #7c3aed);
            --bg-color: #f8fafc;
            --text-main: #0f172a;
            --text-muted: #64748b;
            --card-bg: #ffffff;
            --shadow-subtle: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -2px rgba(0, 0, 0, 0.1);
            --shadow-hover: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 8px 10px -6px rgba(0, 0, 0, 0.1);
            --transition-smooth: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }

        /* --- CSS RESET & BASIC STYLES --- */
        body {
            font-family: 'Inter', system-ui, -apple-system, sans-serif;
            background-color: var(--bg-color);
            color: var(--text-main);
            margin: 0;
            padding: 50px 20px;
            line-height: 1.6;
        }

        .container {
            max-width: 1000px;
            margin: auto;
        }

        /* --- HEADER - CĂN GIỮA & GRADIENT --- */
        .header {
            text-align: center;
            margin-bottom: 60px;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 20px;
        }

        h1 {
            font-size: 3rem;
            font-weight: 800;
            letter-spacing: -1px;
            background: var(--primary-gradient);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            margin: 0;
        }

        .btn-new {
            background: var(--primary-gradient);
            color: white;
            padding: 14px 28px;
            border-radius: 99px;
            text-decoration: none;
            font-weight: 600;
            font-size: 1rem;
            transition: var(--transition-smooth);
            box-shadow: 0 10px 15px -3px rgba(37, 99, 235, 0.3);
        }

        .btn-new:hover {
            transform: translateY(-3px);
            box-shadow: 0 20px 25px -5px rgba(37, 99, 235, 0.4);
        }

        /* --- GRID BÀI VIẾT (AUTO-FILL) --- */
        .grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
            gap: 30px;
        }

        /* --- CARD CAO CẤP (SHADOW & HOVER EFFECT) --- */
        .card {
            background: var(--card-bg);
            padding: 30px;
            border-radius: 20px;
            border: 1px solid #e2e8f0;
            transition: var(--transition-smooth);
            position: relative;
            overflow: hidden;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
        }

        /* Hiệu ứng viền Gradient mờ khi Hover */
        .card::before {
            content: '';
            position: absolute;
            top: 0; left: 0; width: 100%; height: 4px;
            background: var(--primary-gradient);
            opacity: 0;
            transition: var(--transition-smooth);
        }

        .card:hover {
            transform: translateY(-10px);
            border-color: transparent;
            box-shadow: var(--shadow-hover);
        }

        .card:hover::before {
            opacity: 1;
        }

        .card h2 {
            margin-top: 0;
            font-size: 1.5rem;
            font-weight: 700;
            color: var(--text-main);
            line-height: 1.3;
        }

        .card p {
            color: var(--text-muted);
            font-size: 1rem;
            margin-bottom: 25px;
            /* Giới hạn 3 dòng nội dung tóm tắt */
            display: -webkit-box;
            -webkit-line-clamp: 3;
            -webkit-box-orient: vertical;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .detail-link {
            background: #f1f5f9;
            color: #2563eb;
            text-decoration: none;
            font-weight: 600;
            font-size: 0.9rem;
            padding: 10px 20px;
            border-radius: 8px;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            transition: var(--transition-smooth);
            width: fit-content;
        }

        .detail-link:hover {
            background: #e0e7ff;
            gap: 12px;
        }

        /* --- EMPTY STATE - KHI CHƯA CÓ BÀI VIẾT --- */
        .empty-state {
            grid-column: 1 / -1;
            text-align: center;
            padding: 80px;
            background: white;
            border-radius: 20px;
            border: 2px dashed #e2e8f0;
            color: var(--text-muted);
        }

        .empty-state p {
            font-size: 1.2rem;
            margin-bottom: 20px;
        }
    </style>
</head>
<body>
    <div class="container">
        <header class="header">
            <h1>My Premium Blog</h1>
            <a href="/blogposts/new" class="btn-new">+ Viết bài mới</a>
        </header>

        <div class="grid">
            <% if (posts.length > 0) { %>
                <% posts.forEach(post => { %>
                    <div class="card">
                        <h2><%= post.title %></h2>
                        <p><%= post.body.substring(0, 150) %></p>
                        <a href="/blogposts/<%= post._id %>" class="detail-link">➜ Đọc chi tiết</a>
                    </div>
                <% }) %>
            <% } else { %>
                <div class="empty-state">
                    <p>Hiện tại chưa có bài viết nào.</p>
                    <a href="/blogposts/new" class="btn-new" style="display: inline-block;">Hãy tạo bài viết đầu tiên!</a>
                </div>
            <% } %>
        </div>

    </div> </body>
</html>
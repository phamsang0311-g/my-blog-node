<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>Tạo bài viết</title>
    <style>
        body { font-family: sans-serif; background: #f0f2f5; display: flex; justify-content: center; padding-top: 50px; }
        .form-box { background: white; padding: 30px; border-radius: 15px; box-shadow: 0 10px 25px rgba(0,0,0,0.1); width: 400px; }
        input, textarea { width: 100%; padding: 12px; margin: 10px 0; border: 1px solid #ddd; border-radius: 8px; box-sizing: border-box; }
        button { width: 100%; background: #1877f2; color: white; border: none; padding: 12px; border-radius: 8px; font-weight: bold; cursor: pointer; }
        .back { display: block; text-align: center; margin-top: 15px; color: #65676b; text-decoration: none; }
    </style>
</head>
<body>
    <div class="form-box">
        <h2 style="text-align: center;">Viết bài mới</h2>
        <form action="/blogposts/store" method="POST">
            <input type="text" name="title" placeholder="Tiêu đề bài viết" required>
            <textarea name="body" rows="5" placeholder="Nội dung bài viết..." required></textarea>
            <button type="submit">Lưu bài viết</button>
        </form>
        <a href="/" class="back">Quay lại trang chủ</a>
    </div>
</body>
</html>